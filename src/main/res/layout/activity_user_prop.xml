<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserPropActivity">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:orientation="horizontal"
        android:paddingBottom="@dimen/activity_vertical_margin"
        android:paddingLeft="@dimen/activity_horizontal_margin"
        android:paddingRight="@dimen/activity_horizontal_margin"
        android:paddingTop="@dimen/activity_vertical_margin">

    <TextView
        android:id="@+id/user_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>
    <ImageButton
        android:id="@+id/btn_copy_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="1"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/ic_menu_share"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/info_copy_name" />

    <TextView
        android:id="@+id/user_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>
    <ImageButton
        android:id="@+id/btn_copy_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="1"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/ic_menu_share"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_copy_username" />

    <TextView
        android:id="@+id/user_userid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>
    <ImageButton
        android:id="@+id/btn_copy_userid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="1"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/ic_menu_share"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/info_copy_id" />

    <TextView
        android:id="@+id/user_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>

    <TextView
        android:id="@+id/user_statusmsg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>

    <TextView
        android:id="@+id/user_clientname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>

    <TextView
        android:id="@+id/user_ipaddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text=""/>
    <ImageButton
        android:id="@+id/btn_copy_ipaddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="1"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/ic_menu_share"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/info_copy_ip" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:text="@string/user_prop_title_voice_volume" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="fill_horizontal" >

        <SeekBar
            android:id="@+id/user_vol_voiceSeekBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="0.9"
            android:contentDescription="@string/voicevolume"
            android:gravity="center" />

        <Button
            android:id="@+id/defVoiceVolBtn"
            style="?android:attr/buttonStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="0.1"
            android:text="@string/default_" />

    </LinearLayout>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_mutevoiceSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_gravity="center_vertical"
        android:text="@string/user_prop_title_mute_voice" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="center_vertical"
        android:text="@string/user_prop_title_media_volume" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_gravity="fill_horizontal" >

        <SeekBar
            android:id="@+id/user_vol_mediaSeekBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/mediavolume"
            android:layout_weight="0.9" />

        <Button
            android:id="@+id/defMfVolBtn"
            style="?android:attr/buttonStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="0.1"
            android:text="@string/default_" />

    </LinearLayout>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_mutemediaSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_gravity="center_vertical"
        android:text="@string/user_prop_title_mute_media" />




    <!-- Peer Subscriptions Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_marginTop="16dp"
        android:text="@string/user_prop_title_peer_subscriptions"
        style="@style/Base.TextAppearance.AppCompat.Headline" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeusrmsgSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_user_msg" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribechanmsgSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_chan_msg" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribebroadcastmsgSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_broadcast_msg" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribevoiceSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_voice" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribevidSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_vid" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribedeskSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_desk" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribemediaSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_media" />

    <!-- Local Subscriptions Section -->
    <TextView
        android:id="@+id/user_prop_header_local_subscriptions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_marginTop="16dp"
        android:text="@string/user_prop_title_local_subscriptions"
        style="@style/Base.TextAppearance.AppCompat.Headline" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeintercepttxtmsgSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_txtmsg" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeinterceptchanmsgSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_chanmsg" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeinterceptvoiceSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_voice" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeinterceptvidSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_vid" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeinterceptdeskSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_desk" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/user_subscribeinterceptmediaSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:text="@string/user_prop_title_subscribe_intercept_media" />





    <Space
        android:layout_height="match_parent"
        android:layout_columnSpan="2" />

</GridLayout>

</ScrollView>